{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Laravel Dev Server",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "serve", "--port=8080"],
      "port": 8080
    },
    {
      "name": "Vite",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173
    },
    {
      "name": "Queue Listener",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "queue:listen", "--tries=1", "--timeout=0"],
      "port": 0
    },
    {
      "name": "Log Tail (Pail)",
      "runtimeExecutable": "php",
      "runtimeArgs": ["artisan", "pail", "--timeout=0"],
      "port": 0
    }
  ]
}
